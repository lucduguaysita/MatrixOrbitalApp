[Unit]
Description=LCD IP Configuration UI (BGK19264A-7T)
# The program auto-detects and polls for the USB display itself, so the unit
# must NOT wait on a specific device node (the old dev-ttyACM0.device
# dependency made `systemctl start` hang until that device job timed out).
After=NetworkManager.service
Wants=NetworkManager.service

[Service]
Type=simple
ExecStart=/usr/local/bin/lcd_ipconfig
Restart=on-failure
RestartSec=5
User=root

[Install]
WantedBy=multi-user.target
